rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthed() {
      return request.auth != null;
    }

    function isSessionOwner() {
      return isAuthed() && resource.data.user_id == request.auth.uid;
    }

    match /sessions/{sessionId} {
      allow create: if isAuthed() && request.resource.data.user_id == request.auth.uid;
      allow read, update, delete: if isSessionOwner();
    }

    match /savings_logs/{logId} {
      allow create: if isAuthed() && request.resource.data.user_id == request.auth.uid;
      allow read: if isAuthed() && resource.data.user_id == request.auth.uid;
    }

    match /transactions/{txId} {
      allow create: if isAuthed();
      allow read: if false;
    }

    match /users/{userId} {
      allow read, write: if isAuthed() && request.auth.uid == userId;
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
