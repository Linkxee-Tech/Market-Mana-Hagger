APP_ENV=development

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,https://market-mama-haggler.web.app,https://market-mama-haggler.firebaseapp.com

# Gemini
GEMINI_API_KEY=API
GEMINI_TEXT_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.0-flash

# Security
ALLOW_DEV_AUTH_BYPASS=True
REQUESTS_PER_MINUTE_DEFAULT=100
SESSION_TTL_MINUTES=60
VISION_CACHE_TTL_SECONDS=30

# Optional Infrastructure
REDIS_URL=
FIRESTORE_PROJECT_ID=market-mama-haggler
FIREBASE_PROJECT_ID=market-mama-haggler
